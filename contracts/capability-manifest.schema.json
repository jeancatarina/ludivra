{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ludivra.dev/contracts/capability-manifest/v1",
  "title": "Ludivra capability manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "status",
    "version",
    "owner",
    "targets",
    "contracts",
    "examples",
    "dependencies",
    "verification",
    "limitations"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" },
    "status": { "enum": ["planned", "experimental", "stable", "unavailable", "deprecated"] },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "owner": { "type": "string", "minLength": 1 },
    "targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/target" }
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "limitations": {
      "type": "array",
      "items": { "$ref": "#/$defs/limitation" }
    }
  },
  "$defs": {
    "target": {
      "enum": ["native-headless", "browser", "electron", "android", "ios", "console-native"]
    },
    "limitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
