{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ludivra.dev/contracts/run-manifest/v1",
  "title": "Ludivra CLI run manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_generated",
    "schemaVersion",
    "runId",
    "operation",
    "status",
    "exitCode",
    "startedAt",
    "finishedAt",
    "durationMs",
    "command",
    "repositories",
    "toolchain",
    "context",
    "diagnostics",
    "artifacts"
  ],
  "properties": {
    "_generated": { "const": "game" },
    "schemaVersion": { "const": 1 },
    "runId": { "type": "string", "pattern": "^run_[A-Za-z0-9_-]+$" },
    "operation": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed"] },
    "exitCode": { "type": "integer", "minimum": 0 },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "durationMs": { "type": "integer", "minimum": 0 },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "repositories": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine"],
      "properties": {
        "engine": { "$ref": "#/$defs/repository" },
        "project": { "$ref": "#/$defs/repository" }
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engineVersion", "nodeVersion", "platform", "architecture", "toolchainLockSha256", "contractsSha256"],
      "properties": {
        "engineVersion": { "type": "string", "minLength": 1 },
        "nodeVersion": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "toolchainLockSha256": { "$ref": "#/$defs/sha256" },
        "contractsSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "projectId": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "profile": { "type": "string", "minLength": 1 }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["info", "warning", "error"] }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "sha256"],
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/sha256" }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "dirty", "worktreeHash"],
      "properties": {
        "commit": { "type": ["string", "null"], "pattern": "^[a-f0-9]{40}$" },
        "dirty": { "type": ["boolean", "null"] },
        "worktreeHash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
