{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ludivra.dev/contracts/capability-catalog/v1",
  "title": "Ludivra generated capability catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["_generated", "schemaVersion", "engineVersion", "capabilities", "platforms"],
  "properties": {
    "_generated": { "const": "tools/contracts/generate-capabilities.mjs" },
    "schemaVersion": { "const": 1 },
    "engineVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "capabilities": {
      "type": "array",
      "items": { "$ref": "https://ludivra.dev/contracts/capability-manifest/v1" }
    },
    "platforms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["native-headless", "browser", "electron", "android", "ios", "console-native"],
      "properties": {
        "native-headless": { "$ref": "#/$defs/status" },
        "browser": { "$ref": "#/$defs/status" },
        "electron": { "$ref": "#/$defs/status" },
        "android": { "$ref": "#/$defs/status" },
        "ios": { "$ref": "#/$defs/status" },
        "console-native": { "$ref": "#/$defs/status" }
      }
    }
  },
  "$defs": {
    "status": { "enum": ["planned", "experimental", "stable", "unavailable", "deprecated"] }
  }
}
