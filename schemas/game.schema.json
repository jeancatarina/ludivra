{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ludivra.dev/schemas/game/v2",
  "title": "Ludivra game manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "engine", "targets", "entrypoints", "inputs", "inspection", "scenarios"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version"],
      "properties": {
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["browser", "desktop", "android", "ios", "native-headless"]
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gameplay", "presentation"],
      "properties": {
        "gameplay": { "type": "string", "minLength": 1 },
        "presentation": { "type": "string", "minLength": 1 }
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "actionId", "keys"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "label": { "type": "string", "minLength": 1 },
          "actionId": { "type": "integer", "minimum": 1 },
          "keys": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "inspection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["integerStates"],
      "properties": {
        "integerStates": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label", "key"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" },
              "label": { "type": "string", "minLength": 1 },
              "key": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "audio": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "eventId", "bus", "loop", "autoplay", "volume", "origin", "license"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" },
          "eventId": { "type": "integer", "minimum": 1 },
          "bus": { "enum": ["music", "ambience", "effects"] },
          "loop": { "type": "boolean" },
          "autoplay": { "type": "boolean" },
          "volume": { "type": "number", "minimum": 0, "maximum": 1 },
          "origin": { "type": "string", "minLength": 1 },
          "license": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "synth": {
            "type": "object",
            "additionalProperties": false,
            "required": ["waveform", "frequency", "durationMs"],
            "properties": {
              "waveform": { "enum": ["sine", "square", "sawtooth", "triangle"] },
              "frequency": { "type": "number", "minimum": 20, "maximum": 20000 },
              "durationMs": { "type": "integer", "minimum": 10, "maximum": 60000 }
            }
          }
        },
        "oneOf": [
          { "required": ["source"], "not": { "required": ["synth"] } },
          { "required": ["synth"], "not": { "required": ["source"] } }
        ]
      }
    },
    "effects": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "eventId", "type", "color", "count", "size", "speed", "lifetimeMs", "gravity"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" },
          "eventId": { "type": "integer", "minimum": 1 },
          "type": { "const": "particle-burst" },
          "color": { "type": "integer", "minimum": 0, "maximum": 16777215 },
          "count": { "type": "integer", "minimum": 1, "maximum": 5000 },
          "size": { "type": "number", "exclusiveMinimum": 0, "maximum": 10 },
          "speed": { "type": "number", "minimum": 0, "maximum": 100 },
          "lifetimeMs": { "type": "integer", "minimum": 16, "maximum": 60000 },
          "gravity": { "type": "number", "minimum": -100, "maximum": 100 }
        }
      }
    },
    "steam": {
      "type": "object",
      "additionalProperties": false,
      "required": ["appId", "depotId"],
      "properties": {
        "appId": { "type": ["integer", "null"], "minimum": 1 },
        "depotId": { "type": ["integer", "null"], "minimum": 1 }
      }
    },
    "desktop": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "updates": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "feedUrl"],
          "properties": {
            "enabled": { "type": "boolean" },
            "feedUrl": {
              "type": ["string", "null"],
              "pattern": "^https://"
            }
          }
        }
      }
    }
  }
}
